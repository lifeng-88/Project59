    "legal.ua.lead" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitte lesen Sie diese Bedingungen sorgfältig durch, bevor Sie unser KI-gesteuertes Ökosystem nutzen. Durch Ihre Nutzung des Dienstes verpflichten Sie sich rechtlich zu diesen Protokollen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Please read these terms carefully before using our AI-driven ecosystem. Your use of the service constitutes a legal commitment to these protocols."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lea estos términos detenidamente antes de utilizar nuestro ecosistema impulsado por IA. Su uso del servicio constituye un compromiso legal con estos protocolos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veuillez lire attentivement ces conditions avant d'utiliser notre écosystème basé sur l'IA. Votre utilisation du service constitue un engagement juridique envers ces protocoles."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI 主導のエコシステムを使用する前に、これらの規約をよくお読みください。お客様によるサービスの使用は、これらのプロトコルに対する法的約束を構成します。"
          }
        },
        "pt" : {
