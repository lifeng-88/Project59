    "iap.payments_disabled" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In-App-Käufe sind deaktiviert. Aktivieren Sie sie unter „Einstellungen“ → „Bildschirmzeit“ → „Inhalts- und Datenschutzbeschränkungen“ → „In-App-Käufe“ oder überprüfen Sie Ihre Apple-ID."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In-app purchases are disabled. Enable them in Settings → Screen Time → Content & Privacy Restrictions → In-app Purchases, or check your Apple ID."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las compras dentro de la aplicación están deshabilitadas. Habilítelos en Configuración → Tiempo de pantalla → Restricciones de contenido y privacidad → Compras dentro de la aplicación, o verifique su ID de Apple."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les achats intégrés sont désactivés. Activez-les dans Paramètres → Temps d'écran → Restrictions de contenu et de confidentialité → Achats intégrés, ou vérifiez votre identifiant Apple."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アプリ内購入は無効になっています。 「設定」→「スクリーンタイム」→「コンテンツとプライバシーの制限」→「アプリ内購入」でこれらを有効にするか、Apple ID を確認してください。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As compras no aplicativo estão desativadas. Ative-os em Configurações → Tempo de uso → Restrições de conteúdo e privacidade → Compras no aplicativo ou verifique seu ID Apple."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無法使用 App 內購買。請在 設置 → 屏幕使用時間 → 內容與隱私訪問限制 → App 內購買 中允許購買；或檢查是否登錄 Apple ID。"
          }
        }
      }
    },
