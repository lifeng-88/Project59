    "recharge.error.iap_failed_generic" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Zahlung wurde nicht abgeschlossen. Überprüfen Sie Ihr Netzwerk und Ihre Apple-ID. Konfigurieren Sie StoreKit bei Bedarf im Simulator. Falls aufgeladen, überprüfen Sie später den Ladeverlauf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Payment did not complete. Check your network and Apple ID; configure StoreKit in the Simulator if needed. If charged, check recharge history later."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El pago no se completó. Verifique su red y su ID de Apple; configure StoreKit en el simulador si es necesario. Si se cobra, verifique el historial de recargas más tarde."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le paiement n'a pas été effectué. Vérifiez votre réseau et votre identifiant Apple ; configurez StoreKit dans le simulateur si nécessaire. S'il est chargé, vérifiez l'historique de recharge plus tard."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "支払いが完了しませんでした。ネットワークと Apple ID を確認してください。必要に応じて、シミュレーターで StoreKit を構成します。充電した場合は、後で充電履歴を確認してください。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O pagamento não foi concluído. Verifique sua rede e ID Apple; configure StoreKit no Simulador, se necessário. Se estiver carregado, verifique o histórico de recarga mais tarde."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "支付未完成。請檢查網絡與已登錄的 Apple ID；模擬器需在 Xcode 配置 StoreKit 商品。若已扣款請稍後在充值記錄中查看。"
          }
        }
      }
    },
