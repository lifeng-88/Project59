    "legal.privacy.lead" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieses Dokument beschreibt unser Engagement für den Schutz Ihrer digitalen Identität und wie wir Daten in unserem KI-Ökosystem verarbeiten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This document outlines our commitment to protecting your digital identity and how we process data within our AI ecosystem."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este documento describe nuestro compromiso de proteger su identidad digital y cómo procesamos los datos dentro de nuestro ecosistema de IA."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce document décrit notre engagement à protéger votre identité numérique et la manière dont nous traitons les données au sein de notre écosystème d'IA."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この文書では、お客様のデジタル ID を保護するための当社の取り組みと、当社の AI エコシステム内でデータを処理する方法について概説します。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este documento descreve nosso compromisso em proteger sua identidade digital e como processamos dados em nosso ecossistema de IA."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本文說明我們如何保護您的數字身份，以及在 AI 服務中如何處理數據。"
          }
        }
      }
